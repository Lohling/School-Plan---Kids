# ============================================================
# School Plan Kids – Umgebungsvariablen (Vorlage)
# Kopiere diese Datei: cp .env.example .env
# Ersetze alle Platzhalter mit echten Werten!
# ⚠️  Gib die .env NIEMALS ins Repository – sie ist in .gitignore
# ============================================================

# Datenbank-Passwort (mind. 16 Zeichen, zufällig wählen)
DB_PASSWORD=CHANGE_ME_strong_password_here

# JWT Secret für Authentifizierung (mind. 32 Zeichen, zufällig)
# Tipp: openssl rand -base64 48
JWT_SECRET=CHANGE_ME_at_least_32_random_characters_here

# Session Secret (mind. 32 Zeichen, zufällig)
SESSION_SECRET=CHANGE_ME_session_secret_here

# Trigger Secret für externe Webhook-Aufrufe
TRIGGER_SECRET=CHANGE_ME_trigger_secret_here

# Cloudflare Tunnel Token (nur für Produktiv-Deployment nötig)
# Erhalte deinen Token unter: https://one.dash.cloudflare.com/
CLOUDFLARE_TUNNEL_TOKEN=CHANGE_ME_cloudflare_token_here

# Node Umgebung: development | production
NODE_ENV=development
